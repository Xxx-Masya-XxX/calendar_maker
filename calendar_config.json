{
  "canvas": {
    "width": 2480,
    "height": 3508,
    "dpi": 300,
    "orientation": "portrait",
    "background_color": [255, 255, 255],
    "safe_margin": {
      "top": 100,
      "right": 100,
      "bottom": 100,
      "left": 100
    }
  },

  "locale": {
    "language": "ru",
    "first_day_of_week": "monday"
  },

  "layout": {
    "grid_columns": 7,
    "grid_rows": 6,
    "gap": {
      "x": 20,
      "y": 20
    },
    "position": {
      "mode": "relative",
      "relative": {
        "x_align": "center",
        "y_align": "top",
        "offset_x": 0,
        "offset_y": 600
      }
    }
  },

  "defaults": {
    "block": {
      "width": 250,
      "height": 250,
      "padding": {
        "top": 20,
        "right": 20,
        "bottom": 20,
        "left": 20
      },
      "margin": {
        "top": 0,
        "right": 0,
        "bottom": 0,
        "left": 0
      },
      "background_color": [255, 255, 255],
      "border_radius": 0,
      "border_width": 0,
      "border_color": [0, 0, 0],
      "opacity": 1.0
    },

    "text": {
      "font": "C:/Windows/Fonts/arial.ttf",
      "size": 60,
      "color": [0, 0, 0],
      "letter_spacing": 0,
      "line_height": 1.0,
      "position": {
        "mode": "relative",
        "relative": {
          "x_align": "center",
          "y_align": "center",
          "offset_x": 0,
          "offset_y": 0
        }
      }
    }
  },

  "month_title": {
    "inherit_text": "defaults.text",
    "size": 150,
    "font": "C:/Windows/Fonts/mistral.ttf",
    "margin": {
      "top": 150,
      "right": 0,
      "bottom": 80,
      "left": 0
    },
    "position": {
      "mode": "relative",
      "relative": {
        "x_align": "center",
        "y_align": "top",
        "offset_x": 0,
        "offset_y": 0
      }
    }
  },

  "week_day_header": {
    "inherit_block": "defaults.block",
    "inherit_text": "defaults.text",
    "height": 120,
    "background_color": [240, 240, 240],
    "text": {
      "size": 50
    }
  },

  "day": {
    "inherit_block": "defaults.block",
    "inherit_text": "defaults.text"
  },

  "regular_day": {
    "inherit": "day"
  },

  "weekend": {
    "inherit": "day",
    "text": {
      "color": [220, 0, 0]
    },
    "background_color": [255, 240, 240]
  },

  "other_month_day": {
    "inherit": "day",
    "opacity": 0.4,
    "text": {
      "color": [150, 150, 150]
    }
  },

  "today": {
    "inherit": "day",
    "border_width": 6,
    "border_color": [255, 0, 0],
    "background_color": [255, 255, 200]
  },

  "spec_days": [
    {
      "date": "14.02",
      "name": "День святого Валентина",
      "background_color": [255, 220, 230],
      "text": {
        "color": [255, 0, 80]
      },
      "padding": {
        "top": 30,
        "right": 20,
        "bottom": 20,
        "left": 20
      }
    },
    {
      "date": "08.03",
      "name": "Международный женский день",
      "background_color": [255, 230, 255],
      "text": {
        "color": [200, 0, 120]
      }
    }
  ],

  "months": [
    {
      "name": "Январь",
      "background_image": "assets/img/january.jpg"
    },
    {
      "name": "Февраль",
      "background_image": "assets/img/february.jpg"
    }
  ],

  "export": {
    "format": "png",
    "quality": 100
  }
}